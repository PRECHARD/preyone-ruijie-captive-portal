PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=captive_portal
DB_USER=postgres
DB_PASSWORD=your_password_here

DEFAULT_SESSION_MIN=60
SESSION_CLEANUP_INTERVAL_MIN=15
ENABLE_SESSION_CLEANUP=true

ACCESS_LOG_CLEANUP_INTERVAL_MIN=60
ACCESS_LOG_RETENTION_DAYS=30
ENABLE_ACCESS_LOG_CLEANUP=true

# Ruijie AP gateway success-callback URL (leave blank to use original URL fallback)
RUIJIE_SUCCESS_URL=

# Ruijie AP admin password (default: PreyoneNetAccess)
RUIJIE_PASSWORD=

# Node environment — set to 'production' to disable mock modes
NODE_ENV=development

# Portal base URL (used for Pesepay return URL)
BASE_URL=http://localhost:3000

# Pesepay EcoCash integration
PESEPAY_API_KEY=
PESEPAY_API_ID=
PESEPAY_MERCHANT_ID=
PESEPAY_ENCRYPTION_KEY=
PESEPAY_BASE_URL=https://api.pesepay.com

# JWT secret (REQUIRED — app will crash on start if not set; use a strong random value)
JWT_SECRET=change-this-to-a-random-secret
