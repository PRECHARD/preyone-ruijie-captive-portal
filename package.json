{
  "name": "preyone-ruijie-captive-portal",
  "version": "1.0.0",
  "description": "Captive portal sign-up for Ruijie WiFi with PostgreSQL backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "cleanup": "node -r ts-node/register src/cleanup.ts",
    "cleanup-logs": "node -r ts-node/register src/cleanup-logs.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.12.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^2.0.13",
    "@types/uuid": "^10.0.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.0.0",
    "typescript": "^5.5.3",
    "vitest": "^1.0.0"
  }
}
