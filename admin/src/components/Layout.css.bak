.admin-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.admin-nav {
  height: var(--nav-height);
  background: rgba(10, 10, 10, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 8px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.admin-nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.admin-nav-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-left: 14px;
}

.admin-logo {
  height: 90px;
  width: auto;
  filter: drop-shadow(0 0 8px rgba(113, 255, 47, 0.25));
  transition: filter 0.3s;
}
.admin-logo:hover {
  filter: drop-shadow(0 0 16px rgba(113, 255, 47, 0.5));
}

.admin-nav-title {
  font-family: var(--font-display);
  font-size: 1.55rem;
  letter-spacing: 0.04em;
  color: var(--text);
  padding-left: 0.75rem;
  line-height: 1;
  text-transform: uppercase;
  margin-top: 0.6rem;
}

/* ── Top-right user bar ── */
.nav-user {
  display: flex;
  align-items: center;
  gap: 12px;
}

.nav-user-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px rgba(0, 230, 118, 0.6);
  animation: dotPulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes dotPulse {
  0%,
  100% {
    box-shadow: 0 0 6px rgba(0, 230, 118, 0.4);
  }
  50% {
    box-shadow: 0 0 14px rgba(0, 230, 118, 0.8);
  }
}

.nav-user-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
}

.nav-signout-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.nav-signout-btn:hover {
  border-color: var(--red);
  color: var(--red);
  background: rgba(255, 23, 68, 0.06);
}
.nav-signout-btn svg {
  font-size: 16px;
}

/* ── Main Layout ── */
.admin-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.admin-main {
  flex: 1;
  overflow-y: auto;
  padding: 28px;
}

/* ── Sidebar (no user info, just links) ── */
.sidebar {
  width: var(--sidebar-width);
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.sidebar-links {
  flex: 1;
  padding: 10px 8px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 14px;
  background: transparent;
  border: none;
  border-radius: 8px;
  color: var(--text-muted);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
  transition: all 0.18s;
}
.sidebar-link svg {
  font-size: 17px;
  flex-shrink: 0;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.sidebar-link:hover {
  background: var(--surface2);
  color: var(--text);
}
.sidebar-link:hover svg {
  opacity: 1;
}

.sidebar-link.active {
  background: rgba(106, 13, 173, 0.2);
  color: var(--purple-glow);
  font-weight: 600;
}

.sidebar-badge {
  margin-left: auto;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: 99px;
  background: var(--red);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  line-height: 18px;
  text-align: center;
  flex-shrink: 0;
  box-shadow: 0 0 8px rgba(255, 23, 68, 0.5);
  animation: badgePulse 2s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { box-shadow: 0 0 6px rgba(255, 23, 68, 0.4); }
  50% { box-shadow: 0 0 14px rgba(255, 23, 68, 0.8); }
}
.sidebar-link.active svg {
  opacity: 1;
  filter: drop-shadow(0 0 6px rgba(255, 0, 255, 0.4));
}

/* CEO active link gold override */
.role-ceo .sidebar-link.active {
  background: rgba(255, 215, 0, 0.12);
  color: var(--gold);
}
.role-ceo .sidebar-link.active svg {
  filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.5));
}

/* ── Sidebar footer ── */
.sidebar-footer {
  padding: 10px 12px;
  border-top: 1px solid var(--border);
  display: none;
}

/* ── Role badge in nav ── */
.nav-role-badge {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  letter-spacing: 0.5px;
}
.nav-role-badge.staff {
  background: rgba(0, 229, 255, 0.15);
  color: var(--cyan);
}
.nav-role-badge.manager {
  background: rgba(255, 0, 127, 0.15);
  color: var(--pink);
}
.nav-role-badge.ceo {
  background: rgba(255, 215, 0, 0.15);
  color: var(--gold);
  box-shadow: 0 0 12px rgba(255, 215, 0, 0.15);
}

/* ── iOS Toast Notifications ── */
.toast-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 12px 16px;
  pointer-events: none;
}

.toast-banner {
  pointer-events: auto;
  max-width: 420px;
  width: 100%;
  padding: 14px 18px;
  border-radius: 12px;
  background: rgba(20, 20, 30, 0.96);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  animation: toastSlideIn 0.35s ease-out;
}

.toast--success { border-left: 3px solid var(--green); }
.toast--info { border-left: 3px solid var(--purple-glow); }
.toast--warning { border-left: 3px solid var(--gold); }
.toast--error { border-left: 3px solid var(--red); }

.toast-title {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 2px;
}

.toast-message {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.4;
}

@keyframes toastSlideIn {
  from { transform: translateY(-120%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.toast--clickable {
  cursor: pointer;
  transition: transform 0.15s;
}
.toast--clickable:hover {
  transform: scale(1.02);
}

.toast-goto {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--purple-glow);
  margin-left: 6px;
}
